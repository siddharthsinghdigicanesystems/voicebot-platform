# =============================================================================
# VoiceBot Platform — environment variables
# Copy to .env and fill in the values. NEVER commit .env.
# =============================================================================

# -- Core --------------------------------------------------------------------
ENV=development                       # development | staging | production
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
TZ=Asia/Kolkata

# -- OpenAI Realtime (REQUIRED) ---------------------------------------------
OPENAI_API_KEY=sk-replace-me
OPENAI_REALTIME_MODEL=gpt-realtime-2025-08-28
# Alternatives: gpt-realtime (rolling alias to current GA),
#               gpt-realtime-2 (state-of-the-art reasoning, 128k ctx, more $$),
#               gpt-realtime-1.5 (fast/cheap non-reasoning speech-to-speech)
OPENAI_VOICE=alloy                    # alloy | echo | shimmer | verse | ballad | coral | sage
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime

# -- Audio format on the wire -----------------------------------------------
# g711_ulaw is what Tata streams natively, and OpenAI Realtime accepts it,
# so we use it end-to-end with zero resampling. Don't change unless you know why.
AUDIO_FORMAT=g711_ulaw                # g711_ulaw | g711_alaw | pcm16
AUDIO_SAMPLE_RATE=8000

# -- Tata SmartFlo Voice Streaming ------------------------------------------
# Leave blank for local dev with the mock telephony adapter.
# In production, get these from your Tata account manager.
TATA_API_KEY=
TATA_API_BASE_URL=https://api-smartflo.tatateleservices.com
# HMAC secret for verifying inbound webhooks
TATA_WEBHOOK_SECRET=
# Your DID, e.g. 04412345678
TATA_OUTBOUND_CALLER_ID=
# Bearer token Tata sends on the WS connection
TATA_STREAMING_AUTH_TOKEN=

# Which adapter the bridge should use. mock = local browser demo, tata = production.
TELEPHONY_ADAPTER=mock                # mock | tata

# -- Postgres ---------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=voicebot
POSTGRES_USER=voicebot
POSTGRES_PASSWORD=voicebot_dev_pw_change_me
DATABASE_URL=postgresql+asyncpg://voicebot:voicebot_dev_pw_change_me@postgres:5432/voicebot
DATABASE_SSL=disable                  # disable | require

# -- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -- Auth -------------------------------------------------------------------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-64-bytes-of-entropy
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
SERVICE_TOKEN=replace-me-too          # bridge -> api auth (long-lived, single value)

# Default seeded admin (created on first migration)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin                  # CHANGE THIS for any non-local deployment

# -- Service URLs -----------------------------------------------------------
API_INTERNAL_URL=http://api:8000      # how bridge/worker reach the API
API_PUBLIC_URL=http://localhost:8000  # how the browser reaches the API
BRIDGE_PUBLIC_WS_URL=ws://localhost:8080/v1/telephony/tata  # mock telephony + Tata stream both connect here
FRONTEND_PUBLIC_URL=http://localhost:5173

# -- Reverse proxy (docker-compose.prod.yml / Caddy) ------------------------
# Single public domain fronted by Caddy (TLS auto via Let's Encrypt).
# Tata WSS -> wss://$DOMAIN/v1/telephony/tata ; webhooks -> https://$DOMAIN/v1/webhooks/tata
DOMAIN=voice.example.com
ACME_EMAIL=ops@example.com

# -- Recordings -------------------------------------------------------------
# Per-call μ-law audio capture. `disk` writes locally (dev / sidecar);
# `s3` uploads at hangup (prod). For S3 you also need AWS credentials in
# the environment (IAM role on EKS/ECS, or AWS_ACCESS_KEY_ID/etc.).
ENABLE_RECORDINGS=false
RECORDINGS_BACKEND=disk               # disk | s3
RECORDINGS_DIR=/app/recordings        # used when RECORDINGS_BACKEND=disk
# required when RECORDINGS_BACKEND=s3
RECORDINGS_S3_BUCKET=
RECORDINGS_S3_PREFIX=calls            # objects land at <prefix>/YYYY/MM/DD/<call_id>.<track>.ulaw
# leave blank to use AWS_REGION / default chain
RECORDINGS_S3_REGION=
# if set, objects use SSE-KMS with this key
RECORDINGS_S3_KMS_KEY_ID=

# -- Bridge safety knobs ----------------------------------------------------
# Hard upper bound on a single call. The watchdog force-ends the bridge at
# this point. Keep generous for normal calls but small enough that a
# runaway loop can't burn unbounded OpenAI minutes.
MAX_CALL_DURATION_SECONDS=600
# End the call if the caller hasn't spoken for this long *after* the bot
# has spoken at least once. (Common: caller hung up but the carrier didn't
# tell us, or the WS link wedged.)
CALLER_SILENCE_TIMEOUT_SECONDS=30
# End the call if the caller never speaks at all in this window from start.
CALLER_INITIAL_SILENCE_TIMEOUT_SECONDS=45
# Once the model calls transfer_to_human or end_call, the bridge keeps
# streaming bot audio until the model finishes its goodbye response. This
# is the safety cap — if response.done doesn't arrive within the window
# we tear down anyway.
WRAP_UP_GRACE_SECONDS=8

# -- Worker --------------------------------------------------------------
# A `dialing` row older than this gets reverted to `pending` (or `failed`
# if retries exhausted) by the worker's per-tick sweeper. Should be larger
# than dial_timeout + max_call_duration + slack.
SWEEP_STALE_OLDER_THAN_SECONDS=720

# -- Feature flags ----------------------------------------------------------
ENABLE_LIVE_TRANSCRIPT_PUBSUB=true    # bridge publishes transcripts to Redis for live UI
